# Required
PIN=1234

# Optional - Postgres (falls back to SQLite if unset)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# PGSSLMODE=require

# Optional - event identity (all have safe defaults)
EVENT_TITLE=Our Celebration
EVENT_SUBTITLE=
EVENT_HOSTED_BY=
EVENT_DATE_LABEL=
EVENT_DATE_ISO=
RSVP_DEADLINE=
CONTACT_EMAIL=
CONTACT_PHONE=
DRESS_CODE=
GIFT_REGISTRY_URL=

# Server
PORT=3000
PUBLIC_URL=http://localhost:3000

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=25
PDF_BACKEND=auto

# Email channel (Phase 5) — unlocks per-guest Email button, bulk email send,
# auto-reminders, and admin-notify-on-RSVP. Both must be set to activate;
# see docs/RESEND_SETUP.md for the full walkthrough.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=invites@yourdomain.com
# Or with a display name:
# RESEND_FROM_EMAIL=Your Event <invites@yourdomain.com>
